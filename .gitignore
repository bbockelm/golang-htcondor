# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Go workspace: this is a committed multi-module monorepo workspace (core,
# webapi, localcredmon). go.work + go.work.sum are tracked so a fresh checkout
# and CI resolve the workspace the same way; the Makefile's build/test targets
# depend on it. Local per-developer overrides go in go.work.local instead.
go.work.local

# Dependency directories
vendor/

# IDE directories
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Example binaries
examples/*/basic
examples/*/example
examples/basic/basic
examples/file_transfer_demo/file_transfer_demo
examples/param_defaults_demo/param_defaults_demo
examples/queue_demo/queue_demo

# Temporary files and tokens
cmd/htcondor-api/tmp/

# Command binaries
/htcondor-api
/htcondor-mcp
/htcondor-jupyter-helper

# Build output (Makefile `build-prod` writes here)
/bin/
/webapi/httpserver/jupyterhelperbin/dist/

# Go cache directories (when GOCACHE/GOTMPDIR point at the repo)
/.gocache/
/.gotmp/

# Web UI build artifacts. The Next.js export is staged into
# httpserver/webui/dist before the embed_frontend build; only the
# .keep placeholder is tracked so go:embed always finds something.
/webapi/httpserver/webui/dist/*
!/webapi/httpserver/webui/dist/.keep

# HTCondor docs embed dir, staged by `make stage-condor-docs` from
# reference/htcondor/docs. Only the .keep placeholder is tracked so
# go:embed always has a directory to walk under the no-tag build.
/webapi/condordocs/dist/*
!/webapi/condordocs/dist/.keep

# Runtime log files (job.log etc. from running jobs/demos in the repo)
/job.log
/test*.log
/webapi/httpserver/job.log
/webapi/httpserver/test*.log

# Test databases
oauth2.db
oauth2.db-*
*.db

# Reference documentation files
reference/
examples/classadlog_reader/classadlog_reader
