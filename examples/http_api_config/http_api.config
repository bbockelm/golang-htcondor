# HTCondor HTTP API Server Configuration
#
# This file should be placed in /etc/condor/config.d/ or included in your
# HTCondor configuration.

##################################################
# HTTP Server Configuration
##################################################

# Listen address for the HTTP API server
# Format: [host]:port
# Default: :8080
# Examples:
#   :8080              - Listen on all interfaces, port 8080
#   127.0.0.1:8080     - Listen only on localhost
#   :8443              - Listen on all interfaces, port 8443 (HTTPS)
HTTP_API_LISTEN_ADDR = :8080

##################################################
# TLS/HTTPS Configuration (Optional)
##################################################

# Path to TLS certificate file (PEM format)
# If both TLS_CERT and TLS_KEY are specified, the server will use HTTPS
# HTTP_API_TLS_CERT = /etc/condor/certs/server.crt

# Path to TLS private key file (PEM format)
# HTTP_API_TLS_KEY = /etc/condor/certs/server.key

##################################################
# HTTP Timeout Configuration (Optional)
##################################################

# Maximum duration for reading the entire request, including the body
# Format: duration string (e.g., "30s", "1m", "1h30m")
# Default: 30s
HTTP_API_READ_TIMEOUT = 30s

# Maximum duration before timing out writes of the response
# Format: duration string
# Default: 30s
HTTP_API_WRITE_TIMEOUT = 30s

# Maximum amount of time to wait for the next request when keep-alives are enabled
# Format: duration string
# Default: 120s
HTTP_API_IDLE_TIMEOUT = 120s

##################################################
# Authentication Configuration (Optional)
##################################################

# HTTP header name containing the authenticated username
# This is typically used when the HTTP API server is behind a reverse proxy
# that handles authentication (e.g., nginx with auth_request, Apache with auth)
# The proxy should set this header with the authenticated username
# HTTP_API_USER_HEADER = X-Forwarded-User

# Path to JWT signing key file (used in demo mode only)
# This is used to generate JWT tokens for demonstration purposes
# HTTP_API_SIGNING_KEY = /etc/condor/keys/jwt_signing.key

##################################################
# Example Configurations
##################################################

# Example 1: Basic HTTP on custom port
# HTTP_API_LISTEN_ADDR = :9090

# Example 2: HTTPS with self-signed certificate
# HTTP_API_LISTEN_ADDR = :8443
# HTTP_API_TLS_CERT = /etc/condor/certs/server.crt
# HTTP_API_TLS_KEY = /etc/condor/certs/server.key

# Example 3: Behind reverse proxy with longer timeouts
# HTTP_API_LISTEN_ADDR = 127.0.0.1:8080
# HTTP_API_USER_HEADER = X-Forwarded-User
# HTTP_API_READ_TIMEOUT = 60s
# HTTP_API_WRITE_TIMEOUT = 60s
# HTTP_API_IDLE_TIMEOUT = 5m

# Example 4: Production HTTPS with strict timeouts
# HTTP_API_LISTEN_ADDR = :443
# HTTP_API_TLS_CERT = /etc/letsencrypt/live/schedd.example.com/fullchain.pem
# HTTP_API_TLS_KEY = /etc/letsencrypt/live/schedd.example.com/privkey.pem
# HTTP_API_READ_TIMEOUT = 30s
# HTTP_API_WRITE_TIMEOUT = 30s
# HTTP_API_IDLE_TIMEOUT = 120s
